# Main MongoDB Database (for candidates, tasks, etc.)
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGO_DB=interviewSupport

# Teams MongoDB Database (separate database for teams data)
TEAMS_MONGO_URI=mongodb+srv://username:password@teams-cluster.mongodb.net/?retryWrites=true&w=majority
TEAMS_MONGO_DB=teamsDatabase

# Flask Configuration
FLASK_DEBUG=False
FLASK_PORT=5000
FLASK_SECRET_KEY=replace-with-a-random-secret

# Supabase for PO dashboard
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-service-role-key

# Kafka -> Supabase PO ingestion
PO_CONSUMER_ENABLED=True
PO_KAFKA_BROKER=pkc-xxxxx.region.provider.confluent.cloud:9092
PO_KAFKA_USERNAME=your-kafka-username
PO_KAFKA_PASSWORD=your-kafka-password
PO_KAFKA_TOPIC=PO
PO_KAFKA_GROUP_ID=po-backfill-v1
PO_KAFKA_FETCH_GROUP_ID=po-backfill-v1-manual
PO_FETCH_MAX_WAIT_SECONDS=8
PO_FETCH_MAX_MESSAGES=200
PO_FETCH_IDLE_POLLS=3

# Optional PO-only PIN access
# scope=all gives full PO view + fetch access
# scope=team defaults to locking the Team Lead filter unless field/value are supplied
PO_PIN_PROFILES_JSON=[{"label":"PO Admin","pin":"842617","scope":"all"},{"label":"Darshan Team","pin":"531842","scope":"team","team":"Darshan Singh"},{"label":"Anushree Team","pin":"264915","scope":"team","team":"Anusree Vasudevan"},{"label":"Prateek Team","pin":"758431","scope":"team","team":"Prateek Narvariya"},{"label":"Bhavya Team","pin":"913624","scope":"team","team":"Bhavya Dutt"}]
